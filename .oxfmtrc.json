{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "bracketSameLine": false,
  "printWidth": 120,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "sortPackageJson": false,
  "ignorePatterns": [
    "**/*.gen.ts",
    "**/next-env.d.ts",
    "packages/frosted-ui-colors/*.d.ts",
    "packages/frosted-ui/src/helpers/emoji-colors.ts"
  ]
}
