{
  "name": "@frosted-ui/colors",
  "private": false,
  "version": "0.0.0",
  "license": "MIT",
  "description": "Frosted UI Colors",
  "main": "index.js",
  "module": "index.mjs",
  "types": "./index.d.ts",
  "scripts": {
    "build": "bun run clean && tsdown && bun run build-css-modules",
    "build-css-modules": "bun ./scripts/build-css-modules.ts",
    "clean": "rm -f *.css index.js index.mjs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "frosted-ui",
    "colors"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/whopio/frosted-ui.git"
  },
  "homepage": "https://github.com/whopio/frosted-ui",
  "bugs": {
    "url": "https://github.com/whopio/frosted-ui/issues"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "tsdown": "^0.22.12"
  }
}
