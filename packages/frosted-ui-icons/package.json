{
  "name": "@frosted-ui/icons",
  "private": false,
  "version": "0.0.0",
  "license": "MIT",
  "description": "Frosted UI React Icons",
  "main": "./dist/cjs/index.js",
  "types": "./dist/cjs/index.d.ts",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      },
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./*": {
      "require": {
        "types": "./dist/cjs/*.d.ts",
        "default": "./dist/cjs/*.js"
      },
      "import": {
        "types": "./dist/esm/*.d.ts",
        "default": "./dist/esm/*.js"
      }
    }
  },
  "files": [
    "dist/**",
    "index.js",
    "pictograms/**"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/whopio/frosted-ui.git"
  },
  "homepage": "https://github.com/whopio/frosted-ui",
  "bugs": {
    "url": "https://github.com/whopio/frosted-ui/issues"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "bun run clean && bun run build:js",
    "build:js": "bun run build:js:cjs && bun run build:js:esm",
    "build:js:cjs": "tsc --project tsconfig-cjs.json",
    "build:js:esm": "tsc --project tsconfig-esm.json",
    "typecheck": "tsc --project tsconfig-cjs.json --noEmit"
  },
  "peerDependencies": {
    "@types/react": "*",
    "react": "^16.x || ^17.x || ^18.x || ^19.x"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "react": "19.2.7",
    "rimraf": "^6.1.3",
    "typescript": "^7.0.2"
  }
}
