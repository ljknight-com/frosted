{
  "include": ["src/**/*"],
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "module": "esnext",
    "sourceMap": true,
    "outDir": "dist",
    "target": "ES2018",
    "declaration": true,
    "jsx": "react",
    "paths": {
      "*": ["./node_modules/*", "./src/types/*"]
    },
    "rootDir": "./src"
  }
}
