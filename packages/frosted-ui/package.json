{
  "name": "@aussieljk/frosted",
  "version": "0.0.1-1",
  "type": "module",
  "description": "@aussieljk/frosted design system",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./styles.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./styles.css",
    "./styles.lite.css": "./styles.lite.css",
    "./theme.css": "./theme.css",
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./icons/heroicons": {
      "types": "./dist/icons/adapters/heroicons.d.ts",
      "import": "./dist/icons/adapters/heroicons.js"
    },
    "./icons/hugeicons": {
      "types": "./dist/icons/adapters/hugeicons.d.ts",
      "import": "./dist/icons/adapters/hugeicons.js"
    },
    "./icons/lucide": {
      "types": "./dist/icons/adapters/lucide.d.ts",
      "import": "./dist/icons/adapters/lucide.js"
    },
    "./icons/phosphor": {
      "types": "./dist/icons/adapters/phosphor.d.ts",
      "import": "./dist/icons/adapters/phosphor.js"
    },
    "./icons/tabler": {
      "types": "./dist/icons/adapters/tabler.d.ts",
      "import": "./dist/icons/adapters/tabler.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "sideEffects": [
    "./dist/icons/adapters/*"
  ],
  "license": "MIT",
  "files": [
    "dist/**",
    "styles.css",
    "styles.lite.css",
    "theme.css"
  ],
  "scripts": {
    "build": "bun run build:js && bun run build:css",
    "build:js": "tsdown --config tsdown.config.mts && bun scripts/fix-namespace-exports.ts",
    "build:css": "postcss src/styles/index.css -o styles.css && postcss src/styles/theme.css -o theme.css && bun scripts/build-lite-css.ts src/styles/index.css -o styles.lite.css",
    "dev:css": "postcss src/styles/index.css -o styles.css --watch",
    "dev:theme": "postcss src/styles/theme.css -o theme.css --watch",
    "health": "bun x publint && bun x @arethetypeswrong/cli --pack . --profile esm-only --exclude-entrypoints styles.css styles.lite.css theme.css",
    "lint": "bun run lint:js && bun run lint:css",
    "lint:js": "bun x oxlint src cosmos demos",
    "lint:css": "stylelint \"src/**/*.css\"",
    "generate:emoji-colors": "bun scripts/emoji-colors/generate.ts",
    "generate:icon-adapters": "bun scripts/generate-icon-adapters.ts",
    "generate:palettes": "bun scripts/generate-palettes.ts",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist && rm -rf styles.css && rm -rf styles.lite.css && rm -rf theme.css && rm -rf cosmos/generated && rm -rf cosmos-export",
    "prepublishOnly": "bun scripts/check-version.ts && bun run lint && bun run build",
    "release": "npm version prerelease --no-git-tag-version && npm publish --tag latest",
    "cosmos": "concurrently -k -n css,thm,cos \"bun run dev:css\" \"bun run dev:theme\" \"bun run cosmos:serve\"",
    "cosmos:serve": "portless frosted sh -c 'cosmos --port \"$PORT\"'",
    "build-cosmos": "bun run generate:props && cosmos-export",
    "generate:props": "bun ../../tools/props-gen/generate-props.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@internationalized/date": "^3.12.2",
    "@react-aria/calendar": "^3.10.1",
    "@react-aria/datepicker": "^3.17.1",
    "@react-aria/focus": "^3.22.1",
    "@react-aria/i18n": "^3.13.1",
    "@react-aria/utils": "^3.34.1",
    "@react-stately/calendar": "^3.10.1",
    "@react-stately/datepicker": "^3.17.1",
    "classnames": "^2.5.1",
    "credit-card-type": "^10.3.0",
    "react-aria-components": "^1.19.0",
    "tailwindcss": "^4.3.3",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@heroicons/react": "^2.0.0",
    "@hugeicons/core-free-icons": ">=1.0.0",
    "@hugeicons/react": ">=1.0.0",
    "@phosphor-icons/react": "^2.0.0",
    "@tabler/icons-react": ">=2.0.0",
    "@types/react": "*",
    "@types/react-dom": "*",
    "lucide-react": ">=0.300.0",
    "react": "^17.0 || ^18.0 || ^19.0",
    "react-dom": "^17.0 || ^18.0 || ^19.0"
  },
  "peerDependenciesMeta": {
    "@heroicons/react": {
      "optional": true
    },
    "@hugeicons/core-free-icons": {
      "optional": true
    },
    "@hugeicons/react": {
      "optional": true
    },
    "@phosphor-icons/react": {
      "optional": true
    },
    "@tabler/icons-react": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@heroicons/react": "^2.2.0",
    "@hugeicons/core-free-icons": "^4.2.3",
    "@hugeicons/react": "^1.1.9",
    "@napi-rs/canvas": "^1.0.2",
    "@phosphor-icons/react": "^2.1.10",
    "@tabler/icons-react": "^3.45.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-form": "^1.33.2",
    "@tanstack/react-table": "^8.21.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "autoprefixer": "^10.5.4",
    "color-convert": "^3.1.3",
    "concurrently": "^10.0.3",
    "emoji-datasource": "^16.0.0",
    "lucide-react": "^1.26.0",
    "node-vibrant": "^4.0.4",
    "postcss": "^8.5.22",
    "postcss-cli": "^11.0.1",
    "postcss-combine-duplicated-selectors": "^10.0.3",
    "postcss-custom-media": "^12.0.1",
    "postcss-discard-empty": "^8.0.1",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^14.0.0",
    "react": "^19.2.8",
    "react-cosmos": "7.3.0",
    "react-cosmos-plugin-vite": "7.3.0",
    "react-dom": "^19.2.8",
    "react-hook-form": "^7.82.0",
    "stylelint": "^17.14.1",
    "tsdown": "^0.22.13",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/aussieljk/frosted",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aussieljk/frosted.git"
  },
  "bugs": {
    "url": "https://github.com/aussieljk/frosted/issues"
  },
  "engines": {
    "node": ">=20"
  }
}
