{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "*.css",
        "index.js",
        "index.mjs"
      ],
      "inputs": [
        "src/**"
      ]
    },
    "lint": {
      "outputs": []
    },
    "lint:css": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": [
        "build"
      ]
    },
    "build:css": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "styles.css"
      ],
      "inputs": [
        "src/**"
      ]
    },
    "docs#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".output/**",
        "dist/**"
      ],
      "inputs": [
        "src/**",
        "content/**",
        "scripts/**",
        "source.config.ts",
        "vite.config.ts",
        "$TURBO_ROOT$/packages/frosted-ui/src/**"
      ]
    },
    "@aussieljk/frosted#build-storybook": {
      "dependsOn": [
        "@frosted-ui/icons#build",
        "build:css"
      ],
      "outputs": [
        "storybook-static/**"
      ],
      "inputs": [
        "src/**",
        ".storybook/**"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    }
  }
}
