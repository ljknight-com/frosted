{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@aussieljk/frosted#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "styles.css", "styles.lite.css", "theme.css"]
    },
    "@frosted-ui/colors#build": {
      "dependsOn": ["^build"],
      "outputs": ["index.js", "index.mjs", "*.css"]
    },
    "tailwind#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "docs#build": {
      "dependsOn": ["^build"],
      "outputs": [".output/**", "dist/**"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/packages/frosted-ui/src/**"]
    },
    "build:css": {
      "dependsOn": ["^build"],
      "outputs": ["styles.css", "styles.lite.css", "theme.css"]
    },
    "lint": {
      "outputs": []
    },
    "lint:css": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "@aussieljk/frosted#build-storybook": {
      "dependsOn": ["@frosted-ui/icons#build", "build:css"],
      "outputs": ["storybook-static/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
