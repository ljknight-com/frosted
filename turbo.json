{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@aussieljk/frosted#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "styles.css", "styles.lite.css", "theme.css"]
    },
    "build:css": {
      "dependsOn": ["^build"],
      "outputs": ["styles.css", "styles.lite.css", "theme.css"]
    },
    "lint": {
      "outputs": []
    },
    "lint:css": {
      "outputs": []
    },
    "@aussieljk/frosted#build-cosmos": {
      "dependsOn": ["build:css"],
      "outputs": ["cosmos-export/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
