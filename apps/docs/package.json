{
  "name": "docs",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "bun run generate:props && vite dev --open",
    "build": "bun run generate:props && vite build",
    "generate:props": "bun scripts/generate-props.ts",
    "start": "vite preview",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "bun run generate:props && fumadocs-mdx && tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist && rm -rf .output && rm -rf .source && rm -rf .nitro && rm -rf .tanstack && rm -rf src/generated",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@aussieljk/frosted": "workspace:*",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-start": "1.168.27",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.5",
    "fumadocs-mdx": "15.2.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.5",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-config-custom": "workspace:*",
    "nitro": "3.0.260610-beta",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  }
}
