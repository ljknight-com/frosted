{
  "name": "frosted-monorepo",
  "version": "0.0.1-canary.153",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "csstype": "3.1.3",
    "@types/minimatch": "5.1.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  },
  "scripts": {
    "build": "turbo run build",
    "build:cosmos": "turbo run build-cosmos",
    "check": "bun run workflows:check && bun run format:check && turbo run lint typecheck build && bun run --filter=@aussieljk/frosted health",
    "deploy": "bun scripts/deploy.ts",
    "dev": "bun scripts/dev.ts",
    "doctor": "bun scripts/doctor.ts",
    "format": "oxfmt \"**/*.{ts,tsx,js,jsx,mjs,cjs}\"",
    "format:check": "oxfmt --check \"**/*.{ts,tsx,js,jsx,mjs,cjs}\"",
    "lint": "turbo run lint && oxlint scripts ci",
    "new:component": "bun scripts/new-component.ts",
    "prepare": "lefthook install || true",
    "prod": "bun scripts/prod.ts",
    "release": "bun scripts/release.ts",
    "screenshot": "bun scripts/screenshot-demos.ts",
    "typecheck": "turbo run typecheck && tsc --noEmit",
    "workflows": "bun ci/generate.ts",
    "workflows:check": "bun ci/generate.ts --check"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "portless": "^0.15.4",
    "turbo": "^2.10.6",
    "typescript": "^7.0.2",
    "vercel": "^56.5.0"
  },
  "engines": {
    "node": "22.x",
    "bun": ">=1.2"
  },
  "packageManager": "bun@1.3.11",
  "patchedDependencies": {
    "react-cosmos-plugin-vite@7.3.0": "patches/react-cosmos-plugin-vite@7.3.0.patch"
  }
}
