{
  "name": "frosted-monorepo",
  "version": "0.0.1-canary.153",
  "private": true,
  "workspaces": [
    "packages/*",
    "tools/*"
  ],
  "overrides": {
    "csstype": "3.1.3",
    "@types/minimatch": "5.1.2",
    "@types/react": "19.1.10",
    "@types/react-dom": "19.1.10"
  },
  "scripts": {
    "build": "turbo run build",
    "build:cosmos": "turbo run build-cosmos",
    "check": "turbo run lint typecheck build && bun run --filter=@aussieljk/frosted health",
    "dev": "bun scripts/dev.ts",
    "doctor": "bun scripts/doctor.ts",
    "format": "oxfmt",
    "generate:props": "bun run --filter=props-gen generate",
    "lint": "turbo run lint",
    "new:component": "bun scripts/new-component.ts",
    "prepare": "lefthook install || true",
    "screenshot": "bun scripts/screenshot-demos.ts",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "lefthook": "^2.1.10",
    "portless": "^0.15.4",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "turbo": "^2.10.5"
  },
  "engines": {
    "node": "22.x",
    "bun": ">=1.2"
  },
  "packageManager": "bun@1.3.11"
}
